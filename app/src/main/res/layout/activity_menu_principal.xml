<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/titan_background"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:background="@color/titan_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@color/titan_red"
                android:gravity="top"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingTop="30dp"
                android:paddingBottom="40dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.7"
                    android:gravity="top"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_regular"
                        android:text="Bienvenido,"
                        android:textColor="@color/titan_card"
                        android:textSize="18sp"/>

                    <TextView
                        android:id="@+id/txt_administrador_nombre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="Administrador"
                        android:textColor="@color/titan_card"
                        android:textSize="28sp"/>

                    <TextView
                        android:id="@+id/datetime_inicio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/montserrat_regular"
                        android:text="Cargando fecha..."
                        android:textColor="@color/titan_card"
                        android:textSize="14sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.3"
                    android:gravity="center"
                    android:orientation="vertical">

                    <androidx.cardview.widget.CardView
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        app:cardBackgroundColor="@color/titan_bg_avatar"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="14dp">

                        <TextView
                            android:id="@+id/txt_iniciales_administrador"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="AA"
                            android:textAlignment="center"
                            android:textColor="@color/titan_card"
                            android:textSize="26sp" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/seccionTarjetasResumen"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_gravity="bottom"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="15dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="86dp"
                    android:layout_marginHorizontal="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/titan_card"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="2dp">

                        <TextView
                            android:id="@+id/card_cantidad_socios_activos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="0"
                            android:textColor="@color/titan_text_primary"
                            android:textSize="24sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_regular"
                            android:text="Socios Activos"
                            android:singleLine="true"
                            android:ellipsize="end"
                            android:textAlignment="center"
                            android:textColor="@color/titan_nav_inactive"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="86dp"
                    android:layout_marginHorizontal="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/titan_card"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="2dp">

                        <TextView
                            android:id="@+id/card_cantidad_no_socios"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="0"
                            android:textColor="@color/titan_text_primary"
                            android:textSize="24sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_regular"
                            android:text="No Socios"
                            android:singleLine="true"
                            android:ellipsize="end"
                            android:textAlignment="center"
                            android:textColor="@color/titan_nav_inactive"
                            android:textSize="12sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="10dp">

            <LinearLayout
                android:id="@+id/btn_aviso_socios_vencen_hoy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="30dp"
                android:paddingVertical="18dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginVertical="10dp"
                android:background="@drawable/bg_boton_redondeado"
                android:backgroundTint="@color/titan_red"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/txt_cantidad_socios_vencen_hoy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:text="0"
                    android:fontFamily="@font/montserrat_bold"
                    android:textColor="@color/titan_card"
                    android:textSize="20sp"/>

                <TextView
                    android:id="@+id/txt_socios_vencen_hoy"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:layout_gravity="center_vertical"
                    android:text="socios vencen hoy"
                    android:fontFamily="@font/montserrat_bold"
                    android:textColor="@color/titan_card"
                    android:textSize="18sp"/>

                <ImageView
                    android:id="@+id/img_flecha_vencimientos"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_btn_socios_vencen_hoy_triangulo"
                    app:tint="@color/titan_card"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingVertical="20dp"
            android:paddingHorizontal="20dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:fontFamily="@font/montserrat_bold"
                android:text="ACTIVIDAD RECIENTE"
                android:textColor="@color/titan_nav_inactive"
                android:textSize="16sp"/>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:id="@+id/contenedor_actividades_dinamico"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginHorizontal="20sp"
        android:layout_marginBottom="15dp"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/nav_inicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">
            <androidx.cardview.widget.CardView
                android:id="@+id/nav_bg_inicio"
                android:layout_width="42dp"
                android:layout_height="42dp"
                app:cardBackgroundColor="@color/titan_red"
                app:cardCornerRadius="21dp"
                app:cardElevation="0.1dp"
                app:tint="@color/titan_nav_inactive" >
                <ImageView
                    android:id="@+id/nav_ic_inicio"
                    android:layout_width="22dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_casita"
                    app:tint="@color/titan_card"/>
            </androidx.cardview.widget.CardView>
            <TextView
                android:id="@+id/nav_text_inicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:text="Inicio"
                android:textColor="@color/titan_red"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_miembros"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">
            <androidx.cardview.widget.CardView
                android:id="@+id/nav_bg_miembros"
                android:layout_width="42dp"
                android:layout_height="42dp"
                app:cardBackgroundColor="@color/titan_nav_inactive_background"
                app:cardCornerRadius="21dp"
                app:cardElevation="0.1dp">
                <ImageView
                    android:id="@+id/nav_ic_miembros"
                    android:layout_width="28dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_miembros_inactive"/>
            </androidx.cardview.widget.CardView>
            <TextView
                android:id="@+id/nav_text_miembros"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:text="Miembros"
                android:textColor="@color/titan_nav_inactive"
                android:textSize="14sp"/>
        </LinearLayout>



        <LinearLayout
            android:id="@+id/nav_mas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">
            <androidx.cardview.widget.CardView
                android:id="@+id/nav_bg_mas"
                android:layout_width="42dp"
                android:layout_height="42dp"
                app:cardBackgroundColor="@color/titan_nav_inactive_background"
                app:cardCornerRadius="21dp"
                app:cardElevation="0.1dp">
                <ImageView
                    android:id="@+id/nav_ic_mas"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_mas"
                    app:tint="@color/titan_nav_inactive" />
            </androidx.cardview.widget.CardView>
            <TextView
                android:id="@+id/nav_text_mas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:text="Más"
                android:textColor="@color/titan_nav_inactive"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>