<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/titan_background"
    android:orientation="vertical">
    <!-- CAJA PRINCIPAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">
        <!-- BLOQUE SUPERIOR: HEADER + TARJETAS SUPERPUESTAS -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:background="@color/titan_background">
            <!-- HEADER ROJO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@color/titan_red"
                android:gravity="top"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingTop="30dp"
                android:paddingBottom="40dp">
                <!-- Bloque izquierdo -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.7"
                    android:gravity="top"
                    android:orientation="vertical">

                    <!-- Bienvenido, -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat"
                        android:text="Bienvenido,"
                        android:textColor="@color/titan_card"
                        android:textSize="18sp"/>

                    <!-- Nombre usuario -->
                    <TextView
                        android:id="@+id/txt_administrador_nombre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat"
                        android:text="Administrador"
                        android:textColor="@color/titan_card"
                        android:textSize="28sp"
                        android:textStyle="bold"/>

                    <!-- Date time -->
                    <TextView
                        android:id="@+id/datetime_inicio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/montserrat"
                        android:text="Viernes 10 de abril, 2026"
                        android:textColor="@color/titan_card"
                        android:textSize="16sp"/>
                </LinearLayout>

                <!-- Bloque derecho -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.3"
                    android:gravity="center"
                    android:orientation="vertical">

                    <androidx.cardview.widget.CardView
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        app:cardBackgroundColor="@color/titan_avatar"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="14dp">

                        <TextView
                            android:id="@+id/txt_iniciales_administrador"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:fontFamily="@font/montserrat"
                            android:gravity="center"
                            android:text="AA"
                            android:textAlignment="center"
                            android:textColor="@color/titan_card"
                            android:textSize="26sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>

            <!-- TARJETAS DE RESUMEN SUPERPUESTAS -->
            <LinearLayout
                android:id="@+id/seccionTarjetasResumen"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_gravity="bottom"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="30dp">

                <!-- SOCIOS ACTIVOS -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="86dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/titan_card"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="4dp">

                        <!-- Numero -->
                        <TextView
                            android:id="@+id/card_cantidad_socios_activos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat"
                            android:paddingBottom="2dp"
                            android:text="42"
                            android:textColor="@color/titan_text_primary"
                            android:textSize="28sp"
                            android:textStyle="bold"/>

                        <!-- Texto -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat"
                            android:text="Socios\nactivos"
                            android:textAlignment="center"
                            android:textColor="@color/titan_nav_inactive"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- VENCIMIENTOS -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="86dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/titan_card"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="4dp">

                        <!-- Numero -->
                        <TextView
                            android:id="@+id/card_cantidad_vencimientos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat"
                            android:paddingBottom="2dp"
                            android:text="5"
                            android:textColor="@color/titan_red"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <!-- Texto -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat"
                            android:text="Vencen\nhoy"
                            android:textAlignment="center"
                            android:textColor="@color/titan_nav_inactive"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- NO SOCIOS -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="86dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/titan_card"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="4dp">

                        <!-- Numero -->
                        <TextView
                            android:id="@+id/card_cantidad_no_socios"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat"
                            android:paddingBottom="2dp"
                            android:text="10"
                            android:textColor="@color/titan_text_primary"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <!-- Texto -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:fontFamily="@font/montserrat"
                            android:text="No socios"
                            android:textAlignment="center"
                            android:textColor="@color/titan_nav_inactive"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </FrameLayout>

        <!-- BOTON AVISO VENCIMIENTOS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="10dp">
            <LinearLayout
                android:id="@+id/btn_aviso_socios_vencen_hoy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="40dp"
                android:paddingVertical="20dp"
                android:layout_marginHorizontal="32dp"
                android:layout_marginVertical="20dp"
                android:background="@drawable/bg_boton_redondeado"
                android:backgroundTint="@color/titan_red"
                android:textColor="@color/titan_card"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true">
                
                <!-- Numero variable -->
                <TextView
                    android:id="@+id/txt_cantidad_socios_vencen_hoy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="20dp"
                    android:text="5"
                    android:fontFamily="@font/montserrat"
                    android:textColor="@color/titan_card"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Texto -->
                <TextView
                    android:id="@+id/txt_socios_vencen_hoy"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:layout_gravity="center_vertical"
                    android:text="socios vencen hoy"
                    android:fontFamily="@font/montserrat"
                    android:textColor="@color/titan_card"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Triangulito -->
                <ImageView
                    android:id="@+id/img_flecha_vencimientos"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginTop="3dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_btn_socios_vencen_hoy_triangulo"
                    app:tint="@color/titan_card"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ACTIVIDAD RECIENTE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingVertical="30dp"
            android:paddingHorizontal="20dp"
            android:orientation="vertical">

            <!-- TITULO -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:fontFamily="@font/montserrat"
                android:text="ACTIVIDAD RECIENTE"
                android:textColor="@color/titan_nav_inactive"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- LISTA SCROLLEABLE -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Elemento 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="0dp"
                        android:paddingRight="10dp">

                        <!-- Puntito de color de estado -->
                        <TextView
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginTop="7dp"
                            android:layout_marginRight="10dp"
                            android:background="@drawable/bg_punto_verde" />

                        <!-- Contenido -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- Texto info socio/no socio -->
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat"
                                android:maxLines="3"
                                android:text="Cuota cobrada · Matías J. · #158"
                                android:textColor="@color/titan_text_primary"
                                android:textSize="16sp" />

                            <!-- Texto hora -->
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat"
                                android:gravity="end"
                                android:text="12:00"
                                android:textColor="@color/titan_nav_inactive"
                                android:textSize="16sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Separador -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="12dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="@color/titan_nav_inactive"/>

                    <!-- Elemento 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="0dp"
                        android:paddingRight="10dp">

                        <!-- Puntito de color de estado -->
                        <TextView
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginTop="7dp"
                            android:layout_marginRight="10dp"
                            android:background="@drawable/bg_punto_azul" />

                        <!-- Contenido -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- Texto info socio/no socio -->
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat"
                                android:maxLines="3"
                                android:text="Nuevo socio registrado · Mauro F. · #159"
                                android:textColor="@color/titan_text_primary"
                                android:textSize="16sp" />

                            <!-- Texto hora -->
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat"
                                android:gravity="end"
                                android:text="12:00"
                                android:textColor="@color/titan_nav_inactive"
                                android:textSize="16sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Separador -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="12dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="@color/titan_nav_inactive"/>

                    <!-- Elemento 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="0dp"
                        android:paddingRight="10dp">

                        <!-- Puntito de color de estado -->
                        <TextView
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginTop="7dp"
                            android:layout_marginRight="10dp"
                            android:background="@drawable/bg_punto_marron" />

                        <!-- Contenido -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- Texto info socio/no socio -->
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat"
                                android:maxLines="3"
                                android:text="Pago actividad · Judith Grau · Karate"
                                android:textColor="@color/titan_text_primary"
                                android:textSize="16sp" />

                            <!-- Texto hora -->
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat"
                                android:gravity="end"
                                android:text="12:00"
                                android:textColor="@color/titan_nav_inactive"
                                android:textSize="16sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Separador -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="12dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="@color/titan_nav_inactive"/>

                    <!-- Elemento 4 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="0dp"
                        android:paddingRight="10dp">

                        <!-- Puntito de color de estado -->
                        <TextView
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginTop="7dp"
                            android:layout_marginRight="10dp"
                            android:background="@drawable/bg_punto_rojo" />

                        <!-- Contenido -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- Texto info socio/no socio -->
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat"
                                android:maxLines="3"
                                android:text="Cuota vencida · Lucas Luccaroni · #2"
                                android:textColor="@color/titan_text_primary"
                                android:textSize="16sp" />

                            <!-- Texto hora -->
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat"
                                android:gravity="end"
                                android:text="12:00"
                                android:textColor="@color/titan_nav_inactive"
                                android:textSize="16sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Separador -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="12dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="@color/titan_nav_inactive"/>

                    <!-- Elemento 5 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="0dp"
                        android:paddingRight="10dp">
                        <!-- Puntito de color de estado -->
                        <TextView
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginTop="7dp"
                            android:layout_marginRight="10dp"
                            android:background="@drawable/bg_punto_verde" />

                        <!-- Contenido -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- Texto info socio/no socio -->
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat"
                                android:maxLines="3"
                                android:text="Cuota cobrada · Ivan Fangenboim · #157"
                                android:textColor="@color/titan_text_primary"
                                android:textSize="16sp" />

                            <!-- Texto hora -->
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat"
                                android:gravity="end"
                                android:text="12:00"
                                android:textColor="@color/titan_nav_inactive"
                                android:textSize="16sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Separador -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="12dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="@color/titan_nav_inactive"/>

                    <!-- Elemento 6 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="0dp"
                        android:paddingRight="10dp">

                        <!-- Puntito de color de estado -->
                        <TextView
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginTop="7dp"
                            android:layout_marginRight="10dp"
                            android:background="@drawable/bg_punto_rojo" />

                        <!-- Contenido -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- Texto info socio/no socio -->
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat"
                                android:maxLines="3"
                                android:text="Cuota vencida · Edinson Cavani · #144"
                                android:textColor="@color/titan_text_primary"
                                android:textSize="16sp" />

                            <!-- Texto hora -->
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat"
                                android:gravity="end"
                                android:text="12:00"
                                android:textColor="@color/titan_nav_inactive"
                                android:textSize="16sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Separador -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="12dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="@color/titan_nav_inactive"/>

                    <!-- Elemento 7 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="0dp"
                        android:paddingRight="10dp">

                        <!-- Puntito de color de estado -->
                        <TextView
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginTop="7dp"
                            android:layout_marginRight="10dp"
                            android:background="@drawable/bg_punto_marron" />

                        <!-- Contenido -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <!-- Texto info socio/no socio -->
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat"
                                android:maxLines="3"
                                android:text="Pago actividad · Paulo Dybala · Futbol"
                                android:textColor="@color/titan_text_primary"
                                android:textSize="16sp" />

                            <!-- Texto hora -->
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat"
                                android:gravity="end"
                                android:text="12:00"
                                android:textColor="@color/titan_nav_inactive"
                                android:textSize="16sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Separador -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="12dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="@color/titan_nav_inactive"/>

                    <!-- Elemento 8 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="0dp"
                        android:paddingRight="10dp">

                        <!-- Puntito de color de estado -->
                        <TextView
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginTop="7dp"
                            android:layout_marginRight="10dp"
                            android:background="@drawable/bg_punto_marron" />

                        <!-- Contenido -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <!-- Texto info socio/no socio -->
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat"
                                android:maxLines="3"
                                android:text="Pago actividad · Lionel Messi · Futbol"
                                android:textColor="@color/titan_text_primary"
                                android:textSize="16sp" />

                            <!-- Texto hora -->
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat"
                                android:gravity="end"
                                android:text="12:00"
                                android:textColor="@color/titan_nav_inactive"
                                android:textSize="16sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </LinearLayout>

    <!-- BARRA INFERIOR/NAVEGACION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginHorizontal="20sp"
        android:layout_marginBottom="15dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- BOTON INICIO -->
        <LinearLayout
            android:id="@+id/nav_inicio"
