<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:id="@+id/rootListaMiembros"
    android:padding="16dp"
    android:background="@color/titan_background">


    <!-- CAJA PRINCIPAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- BLOQUE SUPERIOR: HEADER + TARJETA SUPERPUESTA -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/titan_background">
            <!-- HEADER ROJO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_gravity="top"
                android:background="@color/titan_red"
                android:orientation="vertical"
                android:paddingHorizontal="6dp"
                android:paddingTop="25dp"
                android:paddingBottom="40dp">

                <!-- Volver a miembros -->
                <LinearLayout
                    android:id="@+id/tvVolver"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="left"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="horizontal"
                    android:padding="6dp">
                    <!-- Triangulito -->
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:layout_marginRight="3dp"
                        android:src="@drawable/flecha_atras_negra"
                        app:tint="@color/titan_card" />

                    <!-- Texto Volver -->
                    <TextView

                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Volver"
                        android:textColor="@color/titan_card"
                        android:textSize="16sp" />

                </LinearLayout>

                <!-- Texto Confirmar Pago -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Confirmar Pago Cuota"
                        android:textStyle="bold"
                        android:textColor="@color/titan_card"
                        android:textSize="26sp"/>
                </LinearLayout>
            </LinearLayout>
            <!-- Texto resuemn -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resumen"
                android:textColor="@color/titan_nav_inactive"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:layout_marginRight="130dp"
                android:layout_marginBottom="60dp"/>
            <!-- TARJETA COMPROBANTE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="100dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardCornerRadius="22dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:paddingHorizontal="22dp"
                        android:paddingVertical="22dp">

                        <!-- Texto socio -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:id="@+id/pago_registrado_socio1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Socio"
                                android:textAlignment="gravity"
                                android:textColor="@color/titan_nav_inactive"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/pago_registrado_socio2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginLeft="140dp"
                                android:text="Lucas Luccaroni#2"
                                android:textAlignment="gravity"
                                android:textSize="14sp" />
                        </LinearLayout>
                        <!-- Texto n° cuota -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:id="@+id/pago_registrado_cuota1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Cuota N°"
                                android:textAlignment="gravity"
                                android:textColor="@color/titan_nav_inactive"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/pago_registrado_cuota2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginLeft="220dp"
                                android:text="26"
                                android:textAlignment="gravity"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Texto vencimiento -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:id="@+id/pago_registrado_vencimiento1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Vencimiento"
                                android:textAlignment="gravity"
                                android:textColor="@color/titan_nav_inactive"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/pago_registrado_vencimiento2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginLeft="140dp"
                                android:text="10/04/2026"
                                android:textAlignment="gravity"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Texto Tipo de Pago -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:id="@+id/pago_registrado_tipopago1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Tipo de pago"
                                android:textAlignment="gravity"
                                android:textColor="@color/titan_nav_inactive"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/pago_registrado_tipopago2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginLeft="160dp"
                                android:text="efectivo"
                                android:textAlignment="gravity"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Texto Monto -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                            <TextView
                                android:id="@+id/pago_registrado_monto1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Monto"
                                android:textAlignment="gravity"
                                android:textColor="@color/titan_nav_inactive"
                                android:textSize="14sp" />
                                <TextView
                                    android:id="@+id/pago_registrado_monto2"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginLeft="200dp"
                                    android:text="$45.000"
                                    android:textAlignment="gravity"
                                    android:textSize="14sp" />
                            </LinearLayout>
                        </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

        </FrameLayout>

        <!-- SECCION BOTONES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingHorizontal="15dp">
            </LinearLayout>
        </LinearLayout>
    <!-- BOTON COMPARTIR COMPROBANTE -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:gravity="center">

        <!-- BOTON -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_pago_registrado_compartir_comprobante"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/titan_red"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Boton conf pago -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Confirmar Pago"
                    android:textAlignment="gravity"
                    android:textColor="@color/titan_card"
                    android:textSize="20sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- BOTON VOLVER A INICIO-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:gravity="center">

        <!-- BOTON -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_pago_registrado_volver_a_inicio"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/titan_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Boton Cancelar-->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Cancelar"
                    android:textAlignment="gravity"
                    android:textColor="@color/titan_nav_inactive"
                    android:textSize="20sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!--Barra inferior-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="72dp"
        app:cardCornerRadius="0dp"
        app:cardBackgroundColor="@color/titan_background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/home"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inicio"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/people"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Miembros"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/money"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cobrar"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/menu"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Más"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>