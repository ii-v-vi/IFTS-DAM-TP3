<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/titan_background"
    android:orientation="vertical">
    <!-- CAJA PRINCIPAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- BLOQUE SUPERIOR: HEADER + TARJETA SUPERPUESTA -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="485dp"
            android:background="@color/titan_background">
            <!-- HEADER ROJO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_gravity="top"
                android:background="@color/titan_bg_grey"
                android:orientation="vertical"
                android:paddingHorizontal="6dp"
                android:paddingTop="25dp"
                android:paddingBottom="40dp">


                <!-- Iniciales socio -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="10sp"
                    android:gravity="center_horizontal">
                    <androidx.cardview.widget.CardView
                        android:layout_width="71dp"
                        android:layout_height="71dp"
                        app:cardBackgroundColor="@color/titan_nav_inactive"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="5dp">
                        <TextView
                            android:id="@+id/txt_iniciales_no_socio"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="LL"
                            android:textAlignment="center"
                            android:textColor="@color/titan_card"
                            android:textSize="32sp"/>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Texto Pago registrado -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="Pago registrado"
                        android:textAlignment="center"
                        android:textColor="@color/titan_card"
                        android:textSize="26sp"/>
                </LinearLayout>

                <!-- Texto Cuota cobrada exitosamente -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_regular"
                        android:text="Actividad cobrada exitosamente"
                        android:textAlignment="center"
                        android:textColor="@color/titan_card"
                        android:textSize="20sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- TARJETA COMPROBANTE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_marginHorizontal="20dp"
                android:layout_gravity="bottom">
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardCornerRadius="22dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:paddingHorizontal="22dp"
                        android:paddingVertical="22dp">

                        <!-- Texto TITAN GYM -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="10"
                            android:text="TITAN GYM"
                            android:fontFamily="@font/montserrat_bold"
                            android:textSize="32sp"
                            android:gravity="center"
                            android:textAlignment="gravity"
                            android:textColor="@color/titan_red"/>

                        <!-- Texto Monto pagado -->
                        <TextView
                            android:id="@+id/pago_registrado_monto_pagado"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="5"
                            android:text="$20.000"
                            android:fontFamily="@font/montserrat_bold"
                            android:textSize="26sp"
                            android:gravity="center"
                            android:textAlignment="gravity"
                            android:textColor="@color/titan_text_primary"/>

                        <!-- Texto Monto cobrado -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Monto cobrado"
                            android:fontFamily="@font/montserrat_bold"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:textAlignment="gravity"
                            android:textColor="@color/titan_nav_inactive"/>

                        <!-- Texto Medio de pago -->
                        <TextView
                            android:id="@+id/pago_registrado_medio_de_pago"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Efectivo"
                            android:fontFamily="@font/montserrat_bold"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:textAlignment="gravity"
                            android:textColor="@color/titan_nav_inactive"/>

                        <!-- Texto dateTime -->
                        <TextView
                            android:id="@+id/pago_registrado_datetime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="10/04/2026"
                            android:fontFamily="@font/montserrat_bold"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:textAlignment="gravity"
                            android:textColor="@color/titan_nav_inactive"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </FrameLayout>

        <!-- SECCION BOTONES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="15dp"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <!-- BOTON COMPARTIR COMPROBANTE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:gravity="center">

                <!-- BOTON -->
                <androidx.cardview.widget.CardView

                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/titan_red"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:id="@+id/btn_pago_registrado_compartir_comprobante"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clickable="true"
                        android:focusable="true">

                        <!-- Texto -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Compartir comprobante"
                            android:fontFamily="@font/montserrat_bold"
                            android:textColor="@color/titan_card"
                            android:textAlignment="gravity"
                            android:textSize="20sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- BOTON VOLVER A INICIO-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:gravity="center">

                <!-- BOTON -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/titan_card"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:id="@+id/btn_pago_registrado_volver_a_inicio"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clickable="true"
                        android:focusable="true">

                        <!-- Texto -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Volver a inicio"
                            android:fontFamily="@font/montserrat_bold"
                            android:textColor="@color/titan_nav_inactive"
                            android:textAlignment="gravity"
                            android:textSize="20sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>