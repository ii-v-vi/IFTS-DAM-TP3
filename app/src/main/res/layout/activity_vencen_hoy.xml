<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/titan_background"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/titan_red"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="20dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:id="@+id/btnVolver"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:minWidth="48dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="volver"
                android:src="@drawable/flechita_bl" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Volver"
                android:textColor="@color/white"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Vencen hoy"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Viernes 10 de abril • 5 socios"
            android:textColor="@color/white"
            android:textSize="14sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        android:layout_marginEnd="12dp"
                        app:cardBackgroundColor="@color/titan_red"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="0dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="LL"
                            android:textColor="@color/white"
                            android:textSize="26sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lucas Luccaroni"
                            android:textSize="16sp"
                            android:fontFamily="@font/montserrat_bold"
                            android:textStyle="bold"
                            android:textColor="@color/black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Socio #2"
                            android:textSize="12sp"
                            android:textColor="@color/titan_nav_inactive" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cuota N°26"
                            android:textSize="12sp"
                            android:textColor="@color/titan_nav_inactive" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnCobrarSocio1"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:minWidth="88dp"
                        android:text="Cobrar"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_red_buttom"
                        android:gravity="center"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        android:layout_marginEnd="12dp"
                        app:cardBackgroundColor="@color/titan_red"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="0dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="ED"
                            android:textColor="@color/white"
                            android:textSize="26sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Edinson Cavani"
                            android:textSize="16sp"
                            android:fontFamily="@font/montserrat_bold"
                            android:textStyle="bold"
                            android:textColor="@color/black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Socio #144p"
                            android:textSize="12sp"
                            android:textColor="@color/titan_nav_inactive" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cuota N°1"
                            android:textSize="12sp"
                            android:textColor="@color/titan_nav_inactive" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnCobrarSocio2"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:minWidth="88dp"
                        android:text="Cobrar"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_red_buttom"
                        android:gravity="center"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        android:layout_marginEnd="12dp"
                        app:cardBackgroundColor="@color/titan_red"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="0dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="CP"
                            android:textColor="@color/white"
                            android:textSize="26sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Carlos Palacios"
                            android:textSize="16sp"
                            android:fontFamily="@font/montserrat_bold"
                            android:textStyle="bold"
                            android:textColor="@color/black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Socio #38"
                            android:textSize="12sp"
                            android:textColor="@color/titan_nav_inactive" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cuota N°2"
                            android:textSize="12sp"
                            android:textColor="@color/titan_nav_inactive" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnCobrarSocio3"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:minWidth="88dp"
                        android:text="Cobrar"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_red_buttom"
                        android:gravity="center"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        android:layout_marginEnd="12dp"
                        app:cardBackgroundColor="@color/titan_red"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="0dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="RB"
                            android:textColor="@color/white"
                            android:textSize="26sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rodrigo Battaglia"
                            android:textSize="16sp"
                            android:fontFamily="@font/montserrat_bold"
                            android:textStyle="bold"
                            android:textColor="@color/black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Socio #23"
                            android:textSize="12sp"
                            android:textColor="@color/titan_nav_inactive" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cuota N°22"
                            android:textSize="12sp"
                            android:textColor="@color/titan_nav_inactive" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnCobrarSocio4"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:minWidth="88dp"
                        android:text="Cobrar"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_red_buttom"
                        android:gravity="center"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        android:layout_marginEnd="12dp"
                        app:cardBackgroundColor="@color/titan_red"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="0dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="AM"
                            android:textColor="@color/white"
                            android:textSize="26sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Agustin Marchesin"
                            android:textSize="16sp"
                            android:fontFamily="@font/montserrat_bold"
                            android:textStyle="bold"
                            android:textColor="@color/black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Socio #34"
                            android:textSize="12sp"
                            android:textColor="@color/titan_nav_inactive" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cuota N°2"
                            android:textSize="12sp"
                            android:textColor="@color/titan_nav_inactive" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnCobrarSocio5"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:minWidth="88dp"
                        android:text="Cobrar"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_red_buttom"
                        android:gravity="center"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="15dp"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/nav_inicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:id="@+id/nav_bg_inicio"
                android:layout_width="42dp"
                android:layout_height="42dp"
                app:cardBackgroundColor="@color/titan_red"
                app:cardCornerRadius="21dp"
                app:cardElevation="0.1dp">

                <ImageView
                    android:id="@+id/nav_ic_inicio"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_casita"
                    app:tint="@color/white" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/nav_text_inicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:text="Inicio"
                android:textColor="@color/titan_red"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_miembros"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:id="@+id/nav_bg_miembros"
                android:layout_width="42dp"
                android:layout_height="42dp"
                app:cardBackgroundColor="@color/titan_nav_inactive"
                app:cardCornerRadius="21dp"
                app:cardElevation="0.1dp">

                <ImageView
                    android:id="@+id/nav_ic_miembros"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_miembros" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/nav_text_miembros"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:text="Miembros"
                android:textColor="@color/titan_nav_inactive"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_cobrar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:id="@+id/nav_bg_cobrar"
                android:layout_width="42dp"
                android:layout_height="42dp"
                app:cardBackgroundColor="@color/titan_nav_inactive"
                app:cardCornerRadius="21dp"
                app:cardElevation="0.1dp">

                <ImageView
                    android:id="@+id/nav_ic_cobrar"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_cobrar"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/nav_text_cobrar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:text="Cobrar"
                android:textColor="@color/titan_nav_inactive"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_mas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:id="@+id/nav_bg_mas"
                android:layout_width="42dp"
                android:layout_height="42dp"
                app:cardBackgroundColor="@color/titan_nav_inactive"
                app:cardCornerRadius="21dp"
                app:cardElevation="0.1dp">

                <ImageView
                    android:id="@+id/nav_ic_mas"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_mas"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/nav_text_mas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:text="Más"
                android:textColor="@color/titan_nav_inactive"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>