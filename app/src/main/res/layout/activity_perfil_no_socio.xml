<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/titan_background"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/titan_bg_grey"
                android:orientation="vertical"
                android:paddingHorizontal="6dp"
                android:paddingTop="25dp"
                android:paddingBottom="50dp">

                <LinearLayout
                    android:id="@+id/btn_volver_a_miembros"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="left"
                    android:orientation="horizontal"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:layout_marginRight="3dp"
                        android:rotation="180"
                        android:src="@drawable/ic_btn_socios_vencen_hoy_triangulo"
                        app:tint="@color/titan_card" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_regular"
                        android:text="Miembros"
                        android:textColor="@color/titan_card"
                        android:textSize="14sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="10sp"
                    android:gravity="center_horizontal">
                    <androidx.cardview.widget.CardView
                        android:layout_width="71dp"
                        android:layout_height="71dp"
                        app:cardBackgroundColor="@color/titan_nav_inactive"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="5dp">
                        <TextView
                            android:id="@+id/txt_iniciales_no_socio"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="JG"
                            android:textAlignment="center"
                            android:textColor="@color/titan_card"
                            android:textSize="32sp"/>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:id="@+id/txt_nombre_no_socio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="Judith Grau"
                        android:textAlignment="center"
                        android:textColor="@color/titan_card"
                        android:textSize="26sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_regular"
                        android:text="No socio/a"
                        android:textAlignment="center"
                        android:textColor="@color/titan_card"
                        android:textSize="20sp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="-30dp"
                android:layout_marginBottom="15dp">
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="22dp"
                        android:paddingVertical="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="5dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="4"
                                android:text="DNI"
                                android:fontFamily="@font/montserrat_bold"
                                android:textSize="14sp"
                                android:textColor="@color/titan_nav_inactive"/>
                            <TextView
                                android:id="@+id/datos_no_socio_dni"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="6"
                                android:text=""
                                android:fontFamily="@font/montserrat_regular"
                                android:textSize="14sp"
                                android:textAlignment="textEnd"
                                android:textColor="@color/titan_text_primary"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="5dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="4"
                                android:text="Email"
                                android:fontFamily="@font/montserrat_bold"
                                android:textSize="14sp"
                                android:textColor="@color/titan_nav_inactive"/>
                            <TextView
                                android:id="@+id/datos_no_socio_email"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="6"
                                android:text=""
                                android:fontFamily="@font/montserrat_regular"
                                android:textSize="14sp"
                                android:textAlignment="textEnd"
                                android:singleLine="true"
                                android:ellipsize="end"
                                android:textColor="@color/titan_text_primary"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="5dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="4"
                                android:text="Teléfono"
                                android:fontFamily="@font/montserrat_bold"
                                android:textSize="14sp"
                                android:textColor="@color/titan_nav_inactive"/>
                            <TextView
                                android:id="@+id/datos_no_socio_telefono"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="6"
                                android:text=""
                                android:fontFamily="@font/montserrat_regular"
                                android:textSize="14sp"
                                android:textAlignment="textEnd"
                                android:textColor="@color/titan_text_primary"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="5dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="4"
                                android:text="Nacimiento"
                                android:fontFamily="@font/montserrat_bold"
                                android:textSize="14sp"
                                android:textColor="@color/titan_nav_inactive"/>
                            <TextView
                                android:id="@+id/datos_no_socio_nacimiento"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="6"
                                android:text=""
                                android:fontFamily="@font/montserrat_regular"
                                android:textSize="14sp"
                                android:textAlignment="textEnd"
                                android:textColor="@color/titan_text_primary"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="5dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="4"
                                android:text="Actividad"
                                android:fontFamily="@font/montserrat_bold"
                                android:textSize="14sp"
                                android:textColor="@color/titan_nav_inactive"/>
                            <TextView
                                android:id="@+id/datos_no_socio_ficha_medica"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="6"
                                android:text=""
                                android:fontFamily="@font/montserrat_regular"
                                android:textSize="14sp"
                                android:textAlignment="textEnd"
                                android:textColor="@color/titan_text_primary"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="10dp"
                android:layout_marginHorizontal="20dp">
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="22dp"
                        android:paddingVertical="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="HISTORIAL DE PAGOS"
                            android:fontFamily="@font/montserrat_bold"
                            android:textSize="14sp"
                            android:layout_marginBottom="12dp"
                            android:textColor="@color/titan_nav_inactive"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="4"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:paddingVertical="4dp"
                                    android:text="Último pago"
                                    android:fontFamily="@font/montserrat_bold"
                                    android:textSize="14sp"
                                    android:textColor="@color/titan_nav_inactive" />
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:paddingVertical="4dp"
                                    android:text="Actividad"
                                    android:fontFamily="@font/montserrat_bold"
                                    android:textSize="14sp"
                                    android:textColor="@color/titan_nav_inactive"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="6"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/datos_no_socio_ultimo_pago"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:paddingVertical="4dp"
                                    android:text=""
                                    android:fontFamily="@font/montserrat_regular"
                                    android:textSize="14sp"
                                    android:textAlignment="textEnd"
                                    android:textColor="@color/titan_text_primary"/>
                                <TextView
                                    android:id="@+id/datos_no_socio_ultima_actividad"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:paddingVertical="4dp"
                                    android:text=""
                                    android:fontFamily="@font/montserrat_regular"
                                    android:textSize="14sp"
                                    android:textAlignment="textEnd"
                                    android:textColor="@color/titan_text_primary"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- SECCIÓN ACCIONES MODIFICADA: Estructura de filas para soportar Cobrar, Editar y el nuevo Eliminar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="30dp"
                android:layout_marginBottom="25dp">

                <!-- Fila Superior de Acciones -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btn_datos_no_socios_cobrar_actividad"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginRight="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/titan_bg_green"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="Cobrar\nActividad"
                                android:fontFamily="@font/montserrat_bold"
                                android:textColor="@color/titan_text_green"
                                android:textSize="14sp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btn_datos_no_socios_editar"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginLeft="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/titan_bg_blue"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="Editar"
                                android:fontFamily="@font/montserrat_bold"
                                android:textColor="@color/titan_text_blue"
                                android:textSize="14sp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Fila Inferior de Acciones: Botón de Eliminación Completa -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:orientation="horizontal">

                    <!-- NUEVO BOTÓN: Eliminar No Socio -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btn_datos_no_socios_eliminar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cardBackgroundColor="@color/titan_bg_red"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="Eliminar No Socio"
                                android:fontFamily="@font/montserrat_bold"
                                android:textColor="@color/titan_red"
                                android:textSize="14sp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>