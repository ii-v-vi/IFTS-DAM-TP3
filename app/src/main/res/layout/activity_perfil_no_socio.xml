<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/titan_background"
    android:orientation="vertical">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <!-- CAJA PRINCIPAL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- BLOQUE SUPERIOR: HEADER + TARJETA SUPERPUESTA -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="485dp"
                android:background="@color/titan_background">
                <!-- HEADER ROJO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_gravity="top"
                    android:background="@color/titan_bg_grey"
                    android:orientation="vertical"
                    android:paddingHorizontal="6dp"
                    android:paddingTop="25dp"
                    android:paddingBottom="40dp">

                    <!-- Volver a miembros -->
                    <LinearLayout
                        android:id="@+id/btn_volver_a_miembros"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="left"
                        android:orientation="horizontal"
                        android:padding="6dp"
                        android:clickable="true"
                        android:focusable="true">
                        <!-- Triangulito -->
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:layout_marginRight="3dp"
                            android:rotation="180"
                            android:src="@drawable/ic_btn_socios_vencen_hoy_triangulo"
                            app:tint="@color/titan_card" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_regular"
                            android:text="Miembros"
                            android:textColor="@color/titan_card"
                            android:textSize="16sp"/>

                    </LinearLayout>

                    <!-- Iniciales socio -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="10sp"
                        android:gravity="center_horizontal">
                        <androidx.cardview.widget.CardView
                            android:layout_width="71dp"
                            android:layout_height="71dp"
                            app:cardBackgroundColor="@color/titan_nav_inactive"
                            app:cardCornerRadius="40dp"
                            app:cardElevation="5dp">
                            <TextView
                                android:id="@+id/txt_iniciales_no_socio"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:fontFamily="@font/montserrat_bold"
                                android:gravity="center"
                                android:text="JG"
                                android:textAlignment="center"
                                android:textColor="@color/titan_card"
                                android:textSize="32sp"/>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>

                    <!-- Nombre apellido socio -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:id="@+id/txt_nombre_no_socio"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="Judith Grau"
                            android:textAlignment="center"
                            android:textColor="@color/titan_card"
                            android:textSize="26sp"/>
                    </LinearLayout>

                    <!-- Texto socio activo -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_regular"
                            android:text="No socio/a"
                            android:textAlignment="center"
                            android:textColor="@color/titan_card"
                            android:textSize="20sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- TARJETA DATOS SOCIO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:layout_marginHorizontal="20dp"
                    android:layout_gravity="bottom">
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cardCornerRadius="22dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:paddingHorizontal="22dp"
                            android:paddingTop="22dp"
                            android:paddingBottom="2dp">

                            <!-- Columna izquierda (TIPO DE DATOS)-->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_weight="2"
                                android:orientation="vertical">

                                <!-- DNI -->
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="DNI"
                                    android:fontFamily="@font/montserrat_bold"
                                    android:textSize="16sp"
                                    android:textAlignment="textStart"
                                    android:textColor="@color/titan_nav_inactive"/>

                                <!-- EMAIL -->
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Email"
                                    android:fontFamily="@font/montserrat_bold"
                                    android:textSize="16sp"
                                    android:textAlignment="textStart"
                                    android:textColor="@color/titan_nav_inactive"/>

                                <!-- TELEFONO -->
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="TelÃ©fono"
                                    android:fontFamily="@font/montserrat_bold"
                                    android:textSize="16sp"
                                    android:textAlignment="textStart"
                                    android:textColor="@color/titan_nav_inactive"/>

                                <!-- NACIMIENTO -->
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Nacimiento"
                                    android:fontFamily="@font/montserrat_bold"
                                    android:textSize="16sp"
                                    android:textAlignment="textStart"
                                    android:textColor="@color/titan_nav_inactive"/>

                                <!-- FICHA MEDICA -->
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Actividad"
                                    android:fontFamily="@font/montserrat_bold"
                                    android:textSize="16sp"
                                    android:textAlignment="textStart"
                                    android:textColor="@color/titan_nav_inactive"/>
                            </LinearLayout>

                            <!-- Columna derecha (DATOS) -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <!-- DNI -->
                                <TextView
                                    android:id="@+id/datos_no_socio_dni"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="123456789"
                                    android:fontFamily="@font/montserrat_regular"
                                    android:textSize="16sp"
                                    android:textAlignment="textEnd"
                                    android:textColor="@color/titan_text_primary"/>

                                <!-- EMAIL -->
                                <TextView
                                    android:id="@+id/datos_no_socio_email"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="judith@gmail.com"
                                    android:fontFamily="@font/montserrat_regular"
                                    android:textSize="16sp"
                                    android:textAlignment="textEnd"
                                    android:textColor="@color/titan_text_primary"/>

                                <!-- TELEFONO -->
                                <TextView
                                    android:id="@+id/datos_no_socio_telefono"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="123456789"
                                    android:fontFamily="@font/montserrat_regular"
                                    android:textSize="16sp"
                                    android:textAlignment="textEnd"
                                    android:textColor="@color/titan_text_primary"/>

                                <!-- NACIMIENTO -->
                                <TextView
                                    android:id="@+id/datos_no_socio_nacimiento"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="01/01/2000"
                                    android:fontFamily="@font/montserrat_regular"
                                    android:textSize="16sp"
                                    android:textAlignment="textEnd"
                                    android:textColor="@color/titan_text_primary"/>

                                <!-- FICHA MEDICA -->
                                <TextView
                                    android:id="@+id/datos_no_socio_ficha_medica"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Karate"
                                    android:fontFamily="@font/montserrat_regular"
                                    android:textSize="16sp"
                                    android:textAlignment="textEnd"
                                    android:textColor="@color/titan_text_primary"/>
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

            </FrameLayout>

            <!-- TARJETA ESTADO DE CUOTA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginVertical="20dp"
                android:layout_marginHorizontal="20dp"
                android:layout_gravity="bottom">
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardCornerRadius="22dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <!-- Titulo -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="22dp"
                            android:paddingTop="22dp"
                            android:paddingBottom="22dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="HISTORIAL DE PAGOS"
                                android:fontFamily="@font/montserrat_bold"
                                android:textSize="16sp"
                                android:textAlignment="textStart"
                                android:textColor="@color/titan_nav_inactive"/>
                        </LinearLayout>

                        <!-- Datos cuota -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:paddingHorizontal="22dp"
                            android:paddingBottom="2dp">

                            <!-- Columna izquierda (TIPO DE DATOS)-->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_weight="2"
                                android:orientation="vertical">

                                <!-- ULTIMO PAGO -->
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Ãšltimo pago"
                                    android:fontFamily="@font/montserrat_bold"
                                    android:textSize="16sp"
                                    android:textAlignment="textStart"
                                    android:textColor="@color/titan_nav_inactive" />

                                <!-- ACTIVIDAD -->
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Actividad"
                                    android:fontFamily="@font/montserrat_bold"
                                    android:textSize="16sp"
                                    android:textAlignment="textStart"
                                    android:textColor="@color/titan_nav_inactive"/>
                            </LinearLayout>

                            <!-- Columna derecha (DATOS) -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <!-- ULTIMO PAGO -->
                                <TextView
                                    android:id="@+id/datos_no_socio_ultimo_pago"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="10/03/2026"
                                    android:fontFamily="@font/montserrat_regular"
                                    android:textSize="16sp"
                                    android:textAlignment="textEnd"
                                    android:textColor="@color/titan_text_primary"/>

                                <!-- ULTIMA ACTIVIDAD -->
                                <TextView
                                    android:id="@+id/datos_no_socio_ultima_actividad"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Karate"
                                    android:fontFamily="@font/montserrat_regular"
                                    android:textSize="16sp"
                                    android:textAlignment="textEnd"
                                    android:textColor="@color/titan_text_primary"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- BOTONES DE ACCION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="30dp"
                android:layout_marginBottom="20dp">

                <!-- COBRAR CUOTA -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_datos_no_socios_cobrar_actividad"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/titan_bg_green"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- Texto -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Cobrar\nActividad"
                            android:fontFamily="@font/montserrat_bold"
                            android:textAlignment="gravity"
                            android:textColor="@color/titan_text_green"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- EDITAR -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_datos_no_socios_editar"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/titan_bg_blue"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- Texto -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Editar"
                            android:fontFamily="@font/montserrat_bold"
                            android:textAlignment="gravity"
                            android:textColor="@color/titan_text_blue"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- INACTIVAR -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_datos_no_socios_inactivar"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/titan_bg_red"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- Texto -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Inactivar"
                            android:fontFamily="@font/montserrat_bold"
                            android:textAlignment="gravity"
                            android:textColor="@color/titan_red"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <!-- BARRA INFERIOR/NAVEGACION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginHorizontal="20sp"
        android:layout_marginBottom="15dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- BOTON INICIO -->
        <LinearLayout
            android:id="@+id/nav_inicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Fondo -->
            <androidx.cardview.widget.CardView
                android:id="@+id/nav_bg_inicio"
                android:layout_width="42dp"
                android:layout_height="42dp"
                app:cardBackgroundColor="@color/titan_nav_inactive_background"
                app:cardCornerRadius="21dp"
                app:cardElevation="0.1dp">

                <!-- Icono -->
                <ImageView
                    android:id="@+id/nav_ic_inicio"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_inicio"
                    app:tint="@color/titan_nav_inactive" />
            </androidx.cardview.widget.CardView>

            <!-- Texto -->
            <TextView
                android:id="@+id/nav_text_inicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:text="Inicio"
                android:textColor="@color/titan_nav_inactive"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- BOTON MIEMBROS -->
        <LinearLayout
            android:id="@+id/nav_miembros"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Fondo -->
            <androidx.cardview.widget.CardView
                android:id="@+id/nav_bg_miembros"
                android:layout_width="42dp"
                android:layout_height="42dp"
                app:cardBackgroundColor="@color/titan_red"
                app:cardCornerRadius="21dp"
                app:cardElevation="0.1dp">

                <!-- Icono -->
                <ImageView
                    android:id="@+id/nav_ic_miembros"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_miembros"
                    app:tint="@color/titan_card" />
            </androidx.cardview.widget.CardView>

            <!-- Texto -->
            <TextView
                android:id="@+id/nav_text_miembros"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:text="Miembros"
                android:textColor="@color/titan_red"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- BOTON COBRAR -->
        <LinearLayout
            android:id="@+id/nav_cobrar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Fondo -->
            <androidx.cardview.widget.CardView
                android:id="@+id/nav_bg_cobrar"
                android:layout_width="42dp"
                android:layout_height="42dp"
                app:cardBackgroundColor="@color/titan_nav_inactive_background"
                app:cardCornerRadius="21dp"
                app:cardElevation="0.1dp">

                <!-- Icono -->
                <ImageView
                    android:id="@+id/nav_ic_cobrar"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_cobrar"
                    app:tint="@color/titan_nav_inactive" />
            </androidx.cardview.widget.CardView>

            <!-- Texto -->
            <TextView
                android:id="@+id/nav_text_cobrar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:text="Cobrar"
                android:textColor="@color/titan_nav_inactive"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- BOTON MAS -->
        <LinearLayout
            android:id="@+id/nav_mas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Fondo -->
            <androidx.cardview.widget.CardView
                android:id="@+id/nav_bg_mas"
                android:layout_width="42dp"
                android:layout_height="42dp"
                app:cardBackgroundColor="@color/titan_nav_inactive_background"
                app:cardCornerRadius="21dp"
                app:cardElevation="0.1dp">

                <!-- Icono -->
                <ImageView
                    android:id="@+id/nav_ic_mas"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_mas"
                    app:tint="@color/titan_nav_inactive" />
            </androidx.cardview.widget.CardView>

            <!-- Texto -->
            <TextView
                android:id="@+id/nav_text_mas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:text="MÃ¡s"
                android:textColor="@color/titan_nav_inactive"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>