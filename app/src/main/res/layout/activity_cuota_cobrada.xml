<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/titan_background"
    android:orientation="vertical">
    <!-- CAJA PRINCIPAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- BLOQUE SUPERIOR: HEADER + TARJETA SUPERPUESTA -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="485dp"
            android:background="@color/titan_background">
            <!-- HEADER ROJO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_gravity="top"
                android:background="@color/titan_red"
                android:orientation="vertical"
                android:paddingHorizontal="6dp"
                android:paddingTop="25dp"
                android:paddingBottom="40dp">

                <!-- Volver a miembros -->
                <LinearLayout
                    android:id="@+id/btn_volver_a_inicio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="left"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="horizontal"
                    android:padding="6dp">
                    <!-- Triangulito -->
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:layout_marginRight="3dp"
                        android:rotation="180"
                        android:src="@drawable/ic_btn_socios_vencen_hoy_triangulo"
                        app:tint="@color/titan_card" />

                    <!-- Texto Inicio -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_regular"
                        android:text="Inicio"
                        android:textColor="@color/titan_card"
                        android:textSize="16sp" />

                </LinearLayout>

                <!-- Iniciales socio -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="10sp"
                    android:gravity="center_horizontal">

                    <androidx.cardview.widget.CardView
                        android:layout_width="71dp"
                        android:layout_height="71dp"
                        app:cardBackgroundColor="@color/titan_bg_avatar"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="5dp">

                        <TextView
                            android:id="@+id/txt_iniciales_socio"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="LL"
                            android:textAlignment="center"
                            android:textColor="@color/titan_card"
                            android:textSize="32sp"/>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Texto Pago registrado -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="Pago registrado"
                        android:textAlignment="center"
                        android:textColor="@color/titan_card"
                        android:textSize="26sp"/>
                </LinearLayout>

                <!-- Texto Cuota cobrada exitosamente -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_regular"
                        android:text="Cuota cobrada exitosamente"
                        android:textAlignment="center"
                        android:textColor="@color/titan_card"
                        android:textSize="20sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- TARJETA COMPROBANTE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_gravity="bottom"
                android:layout_marginHorizontal="20dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardCornerRadius="22dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:paddingHorizontal="22dp"
                        android:paddingVertical="22dp">

                        <!-- Texto TITAN GYM -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="10"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="TITAN GYM"
                            android:textAlignment="gravity"
                            android:textColor="@color/titan_red"
                            android:textSize="32sp"/>

                        <!-- Texto Monto pagado -->
                        <TextView
                            android:id="@+id/pago_registrado_monto_pagado"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="5"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="$45.000"
                            android:textAlignment="gravity"
                            android:textColor="@color/titan_text_primary"
                            android:textSize="26sp"/>

                        <!-- Texto Monto cobrado -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Monto cobrado"
                            android:textAlignment="gravity"
                            android:textColor="@color/titan_nav_inactive"
                            android:textSize="14sp" />

                        <!-- Texto Medio de pago -->
                        <TextView
                            android:id="@+id/pago_registrado_medio_de_pago"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Efectivo"
                            android:textAlignment="gravity"
                            android:textColor="@color/titan_nav_inactive"
                            android:textSize="14sp"/>

                        <!-- Texto dateTime -->
                        <TextView
                            android:id="@+id/pago_registrado_datetime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="10/04/2026"
                            android:textAlignment="gravity"
                            android:textColor="@color/titan_nav_inactive"
                            android:textSize="14sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </FrameLayout>

        <!-- SECCION BOTONES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingHorizontal="15dp">

            <!-- BOTON COMPARTIR COMPROBANTE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:gravity="center">

                <!-- BOTON -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_pago_registrado_compartir_comprobante"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/titan_red"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- Texto -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Compartir comprobante"
                            android:textAlignment="gravity"
                            android:textColor="@color/titan_card"
                            android:textSize="20sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- BOTON VOLVER A INICIO-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:gravity="center">

                <!-- BOTON -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_pago_registrado_volver_a_inicio"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/titan_card"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- Texto -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Volver a inicio"
                            android:textAlignment="gravity"
                            android:textColor="@color/titan_nav_inactive"
                            android:textSize="20sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- BARRA INFERIOR/NAVEGACION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginHorizontal="20sp"
        android:layout_marginBottom="15dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- BOTON INICIO -->
        <LinearLayout
            android:id="@+id/nav_inicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Fondo -->
            <androidx.cardview.widget.CardView
                android:id="@+id/nav_bg_inicio"
                android:layout_width="42dp"
                android:layout_height="42dp"
                app:cardBackgroundColor="@color/titan_nav_inactive_background"
                app:cardCornerRadius="21dp"
                app:cardElevation="0.1dp">

                <!-- Icono -->
                <ImageView
                    android:id="@+id/nav_ic_inicio"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_inicio"
                    app:tint="@color/titan_nav_inactive" />
            </androidx.cardview.widget.CardView>

            <!-- Texto -->
            <TextView
                android:id="@+id/nav_text_inicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:text="Inicio"
                android:textColor="@color/titan_nav_inactive"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- BOTON MIEMBROS -->
        <LinearLayout
            android:id="@+id/nav_miembros"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Fondo -->
            <androidx.cardview.widget.CardView
                android:id="@+id/nav_bg_miembros"
                android:layout_width="42dp"
                android:layout_height="42dp"
                app:cardBackgroundColor="@color/titan_nav_inactive_background"
                app:cardCornerRadius="21dp"
                app:cardElevation="0.1dp">

                <!-- Icono -->
                <ImageView
                    android:id="@+id/nav_ic_miembros"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_miembros"
                    app:tint="@color/titan_nav_inactive" />
            </androidx.cardview.widget.CardView>

            <!-- Texto -->
            <TextView
                android:id="@+id/nav_text_miembros"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:text="Miembros"
                android:textColor="@color/titan_nav_inactive"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- BOTON COBRAR -->
        <LinearLayout
            android:id="@+id/nav_cobrar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Fondo -->
            <androidx.cardview.widget.CardView
                android:id="@+id/nav_bg_cobrar"
                android:layout_width="42dp"
                android:layout_height="42dp"
                app:cardBackgroundColor="@color/titan_red"
                app:cardCornerRadius="21dp"
                app:cardElevation="0.1dp">

                <!-- Icono -->
                <ImageView
                    android:id="@+id/nav_ic_cobrar"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_cobrar"
                    app:tint="@color/titan_card" />
            </androidx.cardview.widget.CardView>

            <!-- Texto -->
            <TextView
                android:id="@+id/nav_text_cobrar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:text="Cobrar"
                android:textColor="@color/titan_red"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- BOTON MAS -->
        <LinearLayout
            android:id="@+id/nav_mas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Fondo -->
            <androidx.cardview.widget.CardView
                android:id="@+id/nav_bg_mas"
                android:layout_width="42dp"
                android:layout_height="42dp"
                app:cardBackgroundColor="@color/titan_nav_inactive_background"
                app:cardCornerRadius="21dp"
                app:cardElevation="0.1dp">

                <!-- Icono -->
                <ImageView
                    android:id="@+id/nav_ic_mas"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_mas"
                    app:tint="@color/titan_nav_inactive" />
            </androidx.cardview.widget.CardView>

            <!-- Texto -->
            <TextView
                android:id="@+id/nav_text_mas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:text="Más"
                android:textColor="@color/titan_nav_inactive"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>