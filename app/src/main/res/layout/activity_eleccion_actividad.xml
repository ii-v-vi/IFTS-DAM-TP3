<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:background="@color/fondoApp"
    android:orientation="vertical">

    <!-- HEADER ROJO REUTILIZABLE -->
    <LinearLayout
        android:id="@+id/llTitulo"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:gravity="start"
        android:orientation="vertical"
        android:background="#D63A27">

        <!-- TITULO DEL HEADER -->
        <TextView
            android:id="@+id/tvTituloNav"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingLeft="15dp"
            android:paddingTop="30dp"
            android:text="Selección de Actividad"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="@color/white">
        </TextView>
    </LinearLayout>

    <!-- TITULO -->
    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Elegí una actividad"
        android:layout_margin="10dp"
        android:textSize="20sp">
    </TextView>

    <!-- SCROLL VIEW PARA EL PANEL DE ACTIVIDADES -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- PANEL DE ACTIVIDADES -->
        <LinearLayout
            android:id="@+id/llActividades"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- SUBCONTENEDOR DE ACTIVIDADES - ZUMBA - PILATES - ELONGACION -->
            <LinearLayout
                android:id="@+id/llZumbaPilatesElongacion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <!-- CARD ZUMBA -->
                <LinearLayout
                    android:id="@+id/llCardZumba"
                    android:layout_width="150dp"
                    android:layout_height="130dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginVertical="16dp"
                    android:background="@color/titan_red"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/imgZumba"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@drawable/zumba">
                    </ImageView>

                    <TextView
                        android:id="@+id/tvZumba"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Zumba">
                    </TextView>
                    <TextView
                        android:id="@+id/tvPrecioZumba"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="18000">
                    </TextView>
                </LinearLayout>

                <!-- CARD PILATES -->
                <LinearLayout
                    android:id="@+id/llCardPilates"
                    android:layout_width="150dp"
                    android:layout_height="130dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginVertical="16dp"
                    android:background="@color/titan_red"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/imgPilates"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@drawable/pilates">
                    </ImageView>

                    <TextView
                        android:id="@+id/tvPilates"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pilates">
                    </TextView>
                    <TextView
                        android:id="@+id/tvPrecioPilates"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$19000">
                    </TextView>
                </LinearLayout>

                <!-- CARD ELONGACION -->
                <LinearLayout
                    android:id="@+id/llCardElongacion"
                    android:layout_width="150dp"
                    android:layout_height="130dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginVertical="16dp"
                    android:background="@color/titan_red"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/imgElongacion"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@drawable/elongacion">
                    </ImageView>

                    <TextView
                        android:id="@+id/tvElongacion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Elongacion">
                    </TextView>
                    <TextView
                        android:id="@+id/tvPrecioElongacion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$15000">
                    </TextView>
                </LinearLayout>
            </LinearLayout>

            <!-- SUBCONTENEDOR DE ACTIVIDADES - KARATE - SPINNING - HIT -->
            <LinearLayout
                android:id="@+id/llKarateSpinningHit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <!-- CARD KARATE -->
                <LinearLayout
                    android:id="@+id/llCardKarate"
                    android:layout_width="150dp"
                    android:layout_height="130dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginVertical="16dp"
                    android:background="@color/titan_red"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/imgKarate"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@drawable/karate">
                    </ImageView>

                    <TextView
                        android:id="@+id/tvKarate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Karate">
                    </TextView>
                    <TextView
                        android:id="@+id/tvPrecioKarate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="20000">
                    </TextView>
                </LinearLayout>

                <!-- CARD SPINNING -->
                <LinearLayout
                    android:id="@+id/llCardSpinning"
                    android:layout_width="150dp"
                    android:layout_height="130dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginVertical="16dp"
                    android:background="@color/titan_red"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/imgSpinning"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@drawable/spinning">
                    </ImageView>

                    <TextView
                        android:id="@+id/tvSpinning"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Spinning">
                    </TextView>
                    <TextView
                        android:id="@+id/tvPrecioSpinning"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$18500">
                    </TextView>
                </LinearLayout>

                <!-- CARD HIT -->
                <LinearLayout
                    android:id="@+id/llCardHit"
                    android:layout_width="150dp"
                    android:layout_height="130dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginVertical="16dp"
                    android:background="@color/titan_red"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/imgHit"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@drawable/hit">
                    </ImageView>

                    <TextView
                        android:id="@+id/tvHit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hit">
                    </TextView>
                    <TextView
                        android:id="@+id/tvPrecioHit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$17000">
                    </TextView>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- BOTON CONTINUAR -->
    <Button
        android:id="@+id/btnContinuar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="100dp"
        android:layout_marginBottom="20dp"
        android:textStyle="bold"
        android:textSize="20sp"
        android:backgroundTint="@color/rojoFuerte"
        android:text="@string/continuar">
    </Button>
</LinearLayout>
